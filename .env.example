# Server Configuration
NODE_ENV=production
PORT=3001

# Database
MONGODB_URI=mongodb://user:password@localhost:27017/lavish-trader

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Daraz API Configuration
DARAZ_APP_KEY=your-daraz-app-key
DARAZ_APP_SECRET=your-daraz-app-secret
DARAZ_ACCESS_TOKEN=your-daraz-access-token
DARAZ_API_URL=https://api.daraz.pk

# Google Cloud Storage (for images)
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=lavish-trader-images
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@lavishtrader.com

# Admin Credentials
ADMIN_EMAIL=admin@lavishtrader.com
ADMIN_PASSWORD=change-this-secure-password

# Sync Configuration
DARAZ_SYNC_INTERVAL=120 # minutes
INVENTORY_SYNC_INTERVAL=60 # minutes

# CORS Configuration
CORS_ORIGIN=https://lavishtrader.com,http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
